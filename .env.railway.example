# Environment Variables Template for Railway Deployment
# Copy this file and set your actual values in Railway's environment variables settings

# ===== REQUIRED =====

# Port for the server (Railway auto-assigns this, usually don't need to set manually)
# PORT=8000

# Path to model checkpoint
# For Ollama: set to model identifier (e.g., "gpt-oss:20b")
# For vLLM/Transformers: set to HuggingFace model ID (e.g., "openai/gpt-oss-20b")
# For local files: set to absolute path in container (e.g., "/app/models/gpt-oss-20b/original/")
MODEL_PATH=gpt-oss:20b

# Inference backend to use
# Options: "ollama", "vllm", "transformers", "triton", "metal"
# Recommended for Railway: "ollama" (easiest) or "vllm" (fastest with GPU)
INFERENCE_BACKEND=ollama

# ===== OPTIONAL - Browser Tool =====

# Browser backend (only needed if using browser tool)
# Options: "exa", "youcom"
# BROWSER_BACKEND=exa

# API key for Exa browser backend (required if BROWSER_BACKEND=exa)
# Get your key at: https://exa.ai/
# EXA_API_KEY=your_exa_api_key_here

# API key for You.com browser backend (required if BROWSER_BACKEND=youcom)
# Get your key at: https://api.you.com/
# YDC_API_KEY=your_youcom_api_key_here

# ===== OPTIONAL - Advanced Configuration =====

# Tensor parallelism size (for multi-GPU setups)
# TP=2

# PyTorch CUDA allocator configuration (helps prevent OOM errors)
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Rank for distributed training (usually auto-set)
# RANK=0
