{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -e '.[torch]'"
  },
  "deploy": {
    "startCommand": "python -m gpt_oss.responses_api.serve --checkpoint $MODEL_PATH --port $PORT --inference-backend $INFERENCE_BACKEND",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheckPath": "/",
    "healthcheckTimeout": 300
  }
}
